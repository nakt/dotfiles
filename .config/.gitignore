# Exclude all by default
*

# Whitelist specific directories and files
!git/
!git/**
!tmux/
!tmux/**
!nvim/
!nvim/**
!zsh/
!zsh/*.zsh
!zsh/completion/
!zsh/completion/.gitkeep
!.gitignore
